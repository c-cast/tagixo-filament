{
    "name": "ccast/tagixo-filament",
    "description": "Filament SDK for Tagixo Visual Builder",
    "type": "library",
    "version": "1.0",
    "keywords": [
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "tagixo"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Mikrowl Team",
            "email": "dev@mikrowl.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ccast/tagixo": "^1.0",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0",
        "symfony/expression-language": "^6.4|^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../tagixo"
        }
    ],
    "autoload": {
        "psr-4": {
            "Ccast\\TagixoFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ccast\\TagixoFilament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ccast\\TagixoFilament\\TagixoFilamentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=1G",
        "format": "vendor/bin/pint",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    }
}
